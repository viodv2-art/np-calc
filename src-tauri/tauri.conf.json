{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "НП Калькулятор",
  "version": "0.3.0",
  "identifier": "ru.domprometei.npcalc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Калькулятор выбросов НП",
        "width": 900,
        "height": 1100,
        "minWidth": 600,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Калькулятор выбросов НП из ж/д цистерн",
    "longDescription": "Расчёт массы выбросов нефтепродуктов при сливе ж/д цистерн по формуле 2.36 (Кузьмин). Тянет температуру и скорость ветра с Open-Meteo.",
    "windows": {
      "wix": {
        "language": "ru-RU"
      }
    }
  }
}
